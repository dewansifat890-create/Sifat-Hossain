# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
APP_URL=
# Use VITE_ prefix if you need to expose keys to the client, but for Gemini SDK, process.env.GEMINI_API_KEY is standard in this environment.
VITE_GEMINI_API_KEY=
